---
import ModoOscuro from '../components/modoOscuro.svelte';
import Layout from '../layouts/Layout.astro';

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
  <main class="min-h-screen flex items-center justify-center bg-linear-to-br from-slate-50 to-slate-100 p-6">
      
      <div class="text-center space-y-8 max-w-2xl">
        
        <div class = "flex justify-center"> <!-- flex para controlar como los articulos flexibles crecen y se encongen-->
          <img 
            src="/foto.jpg.jpeg" 
            alt="Lautaro Saint Martin" 
            class="w-40 h-40 rounded-full object-cover shadow-lg border-4 border-blue-600"
          />
        </div>
        
        <header class="space-y-4">
          <h1 class="text-5xl md:text-6xl font-extrabold text-slate-900 tracking-tight"><!-- cambia la fuente a extra negrita -->
            Hola, soy 
          </h1>
          <h1 class="text-5xl md:text-6xl font-extrabold text-slate-900 tracking-tight">
            <span class="text-blue-600">Lautaro Saint Martin</span>
          </h1>
          <p class="text-xl text-slate-600 font-medium">
            Estudiante de programación enfocado en crear soluciones web modernas.
          </p>
        </header>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4"> <!--gap sirve para pontrolar espacios/canaletas entre elementos de cuadriculaa y flexbox -->
          <a href="/experiencia" class="w-full sm:w-auto">
            <button class="w-full px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl transition-all shadow-lg hover:-translate-y-1 active:scale-95 text-lg">
              Ver mi Curriculum
            </button>
          </a>
          
          <a href="https://github.com/lautarosaintmartin" target="_blank" class="w-full sm:w-auto"> <!-- sirve para aplicar estilos a un elemento que es el objetivo actual de la navegación, w-full para establecer el ancho al 100% como su contenedor padre, sm:w-auto sirve para establecer el ancho automatico de un elemento solo en pantallas de tamaño mediano -->
            <button class="w-full px-8 py-4 bg-white border border-slate-200 text-slate-700 font-bold rounded-xl hover:bg-slate-50 transition-all hover:-translate-y-1 active:scale-95 text-lg "> <!-- transition all, se utiliza para animar cambios en todas las propiedades CSS, -->
              Mi GitHub
            </button>
          </a>
        </div>

      </div>

    </main>
    
    <style>
      :global(.dark-mode) { /* :global es un selector para que una clase o identificador no sea modificado por el compilador */
        filter: invert(1) hue-rotate(180deg);
    }
      :global(.dark-mode img) {
        filter: invert(1) hue-rotate(180deg);
    }
      :global(.dark-mode button){
        filter: invert(1) hue-rotate(180deg) /*hue rotate para rotar el tono de un color */
      }
    </style>
      
    <ModoOscuro client:load />

</Layout>